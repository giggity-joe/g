    if state.speedBoost then
        local hum = char:WaitForChild("Humanoid")
        hum.WalkSpeed = SPEED_BOOST_AMOUNT
    end
end)

-- Auto Kick loop (fires server kick attempt when a tool is stolen)
-- NOTE: actual kick requires server-side scripts; this is a client-side stub
-- You can hook this into your own RemoteEvent if needed
RunService.Heartbeat:Connect(function()
    if state.autoKick then
        -- Add your auto-kick logic here
        -- Example: fire a RemoteEvent to your server script
        -- game.ReplicatedStorage.YourRemote:FireServer("kick")
    end

    if state.autoPotion then
        -- Add your auto-potion logic here
        -- Example: use a tool in backpack automatically
        local char = LocalPlayer.Character
        if char then
            local backpack = LocalPlayer:FindFirstChild("Backpack")
            if backpack then
                local potion = backpack:FindFirstChild("Potion") -- Change "Potion" to your tool name
                if potion then
                    -- equip and activate
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        hum:EquipTool(potion)
                    end
                end
            end
        end
    end
end)

