-- ===================== TOGGLE LOGIC =====================
local function setToggle(box, active)
    if active then
        TweenService:Create(box, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(0, 220, 0)
        }):Play()
    else
        TweenService:Create(box, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(180, 0, 0)
        }):Play()
    end
end

SpeedBox.MouseButton1Click:Connect(function()
    state.speedBoost = not state.speedBoost
    setToggle(SpeedBox, state.speedBoost)

    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = state.speedBoost and SPEED_BOOST_AMOUNT or 16
        end
    end
end)

KickBox.MouseButton1Click:Connect(function()
    state.autoKick = not state.autoKick
    setToggle(KickBox, state.autoKick)
end)

PotionBox.MouseButton1Click:Connect(function()
